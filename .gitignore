# Generated diagnostics, captures, and local UI state
diagnostics/
imgui.ini
*.ngfx-capture
*.ngfx-gputrace

# `diagnostics/` also matches this source directory. Keep the capture-manifest contract visible
# without surfacing generated diagnostics or the rest of the pre-existing ignored subtree.
!src/engine/platform/diagnostics/
src/engine/platform/diagnostics/*
!src/engine/platform/diagnostics/CaptureManifest.h

# Ad-hoc local test and startup logs
err.txt
out.txt
*_err.txt
*_out.txt
run_*.txt
startup_log.txt

# MSVC build by-products that can escape a build directory
*.pdb
*.ilk
*.idb
*.ipch
